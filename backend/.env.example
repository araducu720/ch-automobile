APP_NAME="C-H Automobile"
APP_ENV=local
# IMPORTANT: Generate with `php artisan key:generate`
APP_KEY=
# WARNING: MUST be false in production!
APP_DEBUG=false
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
# Use "warning" or "error" in production
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ch_automobile
# WARNING: Create a dedicated non-root DB user for production!
DB_USERNAME=ch_auto
DB_PASSWORD=

BROADCAST_CONNECTION=log
CACHE_STORE=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=database
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
# WARNING: Set a strong password in production!
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="info@ch-automobile.de"
MAIL_FROM_NAME="${APP_NAME}"

# Mobile.de API
MOBILE_DE_API_KEY=
MOBILE_DE_DEALER_ID=

# Admin credentials (seeder only — CHANGE IMMEDIATELY after first login)
ADMIN_NAME="C-H Admin"
ADMIN_EMAIL=admin@ch-automobile.de
# IMPORTANT: Set a strong unique password! Never use defaults in production.
ADMIN_PASSWORD=

SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://localhost:7700
# IMPORTANT: Set a strong master key for Meilisearch in production!
MEILISEARCH_KEY=

MEDIA_DISK=public
