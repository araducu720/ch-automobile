APP_NAME="C-H Automobile"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://ch-automobile.eu

APP_LOCALE=ro
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=de_DE

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# --------------------------------------------------------------------------
# Database — MySQL 8 on Forge
# --------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ch_automobile
DB_USERNAME=forge
DB_PASSWORD=

# --------------------------------------------------------------------------
# Session / Cache / Queue → Redis
# --------------------------------------------------------------------------
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --------------------------------------------------------------------------
# Horizon
# --------------------------------------------------------------------------
HORIZON_BALANCE_STRATEGY=auto
HORIZON_MIN_PROCESSES=1
HORIZON_MAX_PROCESSES=10

# --------------------------------------------------------------------------
# Ollama (local LLM — running on the same VPS)
# --------------------------------------------------------------------------
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_VISION_MODEL=llama3.2-vision:11b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=120

# --------------------------------------------------------------------------
# Facebook / Meta
# --------------------------------------------------------------------------
# App credentials (from developers.facebook.com)
FB_APP_ID=
FB_APP_SECRET=

# Long-lived Page Access Token
# Generate with: GET /oauth/access_token?grant_type=fb_exchange_token&…
FB_PAGE_ACCESS_TOKEN=

# Your Facebook Page numeric ID
FB_PAGE_ID=

# Business Manager numeric ID
FB_BUSINESS_ID=

# Commerce Catalog (Vehicles) numeric ID
FB_CATALOG_ID=

# A random string YOU choose — enter the same value in the Meta Developer console
FB_WEBHOOK_VERIFY_TOKEN=

# Graph API version
FB_API_VERSION=v21.0

# Override the AI model for Facebook content (default = OLLAMA_MODEL)
# FB_AI_MODEL=qwen2.5:7b

# Max Graph API calls per hour (conservative; Meta allows ~200/hr)
FB_RATE_LIMIT_PER_HOUR=180

# Max group posts per day (global default, can be overridden per group)
FB_GROUPS_MAX_PER_DAY=3

# --------------------------------------------------------------------------
# Mail
# --------------------------------------------------------------------------
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@ch-automobile.eu"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
