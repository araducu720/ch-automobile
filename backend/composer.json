{
    "name": "ch-automobile/backend",
    "type": "project",
    "description": "C-H Automobile & Exclusive Cars - Backend API & Admin Panel",
    "keywords": ["laravel", "filament", "automobile", "dealer"],
    "license": "proprietary",
    "require": {
        "php": "^8.4",
        "barryvdh/laravel-dompdf": "^3.1",
        "filament/filament": "^3.2",
        "filament/spatie-laravel-media-library-plugin": "^3.3",
        "filament/spatie-laravel-translatable-plugin": "^3.3",
        "guzzlehttp/guzzle": "^7.8",
        "http-interop/http-factory-guzzle": "^1.2",
        "laravel/framework": "^11.0",
        "laravel/sanctum": "^4.0",
        "laravel/scout": "^10.0",
        "laravel/tinker": "^2.9",
        "meilisearch/meilisearch-php": "^1.6",
        "spatie/laravel-medialibrary": "^11.0",
        "spatie/laravel-permission": "^6.4",
        "spatie/laravel-settings": "^3.3",
        "spatie/laravel-sitemap": "^7.2",
        "spatie/laravel-sluggable": "^3.6",
        "spatie/laravel-translatable": "^6.8"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.14",
        "laravel/sail": "^1.31",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "larastan/larastan": "^2.9",
        "pestphp/pest": "^2.34",
        "pestphp/pest-plugin-laravel": "^2.3"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
