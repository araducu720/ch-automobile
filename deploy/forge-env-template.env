APP_NAME="C-H Automobile"
APP_ENV=production
APP_KEY=                                # php artisan key:generate
APP_DEBUG=false
APP_URL=https://ch-automobile.eu

APP_LOCALE=ro
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=info

# ─── Database ────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ch_automobile
DB_USERNAME=forge
DB_PASSWORD=                            # Set in Forge Environment tab

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Session / Cache / Queue ─────────────────────────────────────────────────
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis
CACHE_STORE=redis

# ─── Horizon ─────────────────────────────────────────────────────────────────
HORIZON_BALANCE_STRATEGY=auto
HORIZON_MIN_PROCESSES=1
HORIZON_MAX_PROCESSES=10

# ─── Ollama (local LLM) ──────────────────────────────────────────────────────
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_VISION_MODEL=llama3.2-vision:11b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=120

# ─── Facebook / Meta ─────────────────────────────────────────────────────────
FB_APP_ID=
FB_APP_SECRET=
FB_PAGE_ACCESS_TOKEN=
FB_PAGE_ID=
FB_BUSINESS_ID=
FB_CATALOG_ID=
FB_WEBHOOK_VERIFY_TOKEN=               # A random secret string you choose
FB_API_VERSION=v21.0
FB_RATE_LIMIT_PER_HOUR=180
FB_GROUPS_MAX_PER_DAY=3

# ─── Mail ────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@ch-automobile.eu"
MAIL_FROM_NAME="C-H Automobile"
